{
  "manifest_version": 3,
  "name": "MORRAYA",
  "short_name": "MORRAYA",
  "version": "1.0.0",
  "description": "Invierte el cambio de tus compras diarias en CETES tokenizados en Monad.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.sand.etherfuse.com/*",
    "https://stablebonds.etherfuse.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "MORRAYA"
  }
}
