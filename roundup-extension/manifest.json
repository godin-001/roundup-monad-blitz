{
  "manifest_version": 3,
  "name": "RoundUp — Invierte tu cambio en Monad",
  "version": "1.0",
  "description": "Redondea tus pagos e invierte el cambio en crypto usando Monad.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["ethers.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
